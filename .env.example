DB_USER=postgres
DB_PASS=changeme
DB_NAME=products_db

# Use one of the following connection styles:
# 1) Cloud SQL Unix socket in Cloud Functions
INSTANCE_CONNECTION_NAME=your-project:your-region:your-instance
DB_SOCKET_PATH=/cloudsql

# 2) TCP host/port (local or private IP)
# DB_HOST=127.0.0.1
# DB_PORT=5432

PRICE_CURRENCY=USD
APP_BASE_URL=http://localhost:8080
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Commission form + email delivery
COMMISSION_GCS_BUCKET=soggy-commission-requests
COMMISSION_FROM_EMAIL=soggystitches@gmail.com
COMMISSION_BUSINESS_EMAIL=soggystitches@gmail.com
COMMISSION_COMPANY_NAME=Soggy Stitches
# Optional public brand image used at the top of HTML emails
COMMISSION_EMAIL_HEADER_IMAGE_URL=https://storage.googleapis.com/soggy-public/emails/logo-fly.svg
# Gmail-friendly mode: if SMTP_SERVICE=gmail (or SMTP_USER is a gmail address and SMTP_HOST is blank),
# the app will use Nodemailer's Gmail transport settings automatically.
SMTP_SERVICE=gmail
# Optional for non-Gmail SMTP relays:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
SMTP_USER=soggystitches@gmail.com
SMTP_PASS=ibbb gshl vkor acag
# Optional, applied to all Checkout line items as product_data.tax_code
# Example for tangible goods: txcd_99999999
STRIPE_TAX_CODE=
DB_POOL_MAX=5
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
DB_SSL=false
